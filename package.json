{
  "name": "css-server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "npm run build:css && tauri build",
    "build:css": "sass src/styles/main.scss src/styles.css --no-source-map",
    "watch:css": "sass src/styles/main.scss src/styles.css --watch --no-source-map",
    "test": "node --test tests/e2e.test.js",
    "tauri": "tauri"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "concurrently": "^10.0.3",
    "sass": "^1.101.0"
  },
  "dependencies": {
    "@tauri-apps/api": "^2"
  }
}
